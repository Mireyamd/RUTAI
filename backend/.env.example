# RUTAI API configuration
APP_NAME=RUTAI API
APP_VERSION=0.1.0
APP_ENV=development

# Backward-compatible alias. APP_ENV is preferred for new configuration.
ENVIRONMENT=development

# CORS: "*" allows all origins in development, or use a comma-separated list.
# Example: CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGINS=*

# PostgreSQL/Supabase preparation.
# These variables are not required for local mock-based execution yet.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Legacy placeholder kept only for old local .env files. Do not use for new code.
SUPABASE_KEY=
